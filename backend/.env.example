PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/tla_hrms

# JWT
JWT_ACCESS_SECRET=change_this_access_secret_to_a_long_random_value
JWT_REFRESH_SECRET=change_this_refresh_secret_to_a_long_random_value
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=10

# Mail (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM="TLA HRMS <no-reply@tlahrms.com>"

# Default Super Admin (used by seeder)
SEED_ADMIN_NAME=Super Admin
SEED_ADMIN_EMAIL=admin@tlahrms.com
SEED_ADMIN_PASSWORD=Admin@12345

# Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# Biometric device (ZKTeco K40)
# Milliseconds between background attendance polls. Set to 0 to disable.
BIOMETRIC_POLL_INTERVAL_MS=60000
# Socket timeout for K40 requests (ms).
BIOMETRIC_TIMEOUT_MS=5000
# Set to true to run without a real device (in-memory mock — DEV ONLY).
BIOMETRIC_MOCK=false
# Interval for the device health monitor (ms). Set to 0 to disable.
DEVICE_HEALTH_INTERVAL_MS=30000
# Interval for flushing buffered device metrics to Mongo (ms).
DEVICE_METRICS_FLUSH_MS=5000
# Stale-lease timeout for the attendance import lock (ms).
ATTENDANCE_LOCK_LEASE_MS=300000
# Set to true to delete users on the device that don't exist in HRMS
# during syncAllEmployees. Default false — safer on shared devices.
BIOMETRIC_DELETE_ORPHANS=false

# Logging (error | warn | info | http | debug)
LOG_LEVEL=info

# --- MongoDB pool tuning (all optional) ---
MONGO_POOL_MAX=20
MONGO_POOL_MIN=2
MONGO_MAX_IDLE_MS=60000
MONGO_SERVER_SELECTION_MS=10000
MONGO_SOCKET_MS=45000
MONGO_HEARTBEAT_MS=10000
# Comma-separated wire compressors. Server falls back silently if unsupported.
MONGO_COMPRESSORS=zstd,zlib

# --- Realtime socket ---
# Set to `required` to reject anonymous socket connections. Default: optional.
SOCKET_AUTH=optional
# Server disconnects sockets after this idle window (ms).
SOCKET_IDLE_MS=1800000

# --- Optional Redis cache layer ---
# Leave empty to use the in-process fallback. When set, `ioredis` must be
# installed (npm install ioredis). The app never crashes if Redis is down.
REDIS_URL=
CACHE_MAX_LOCAL_KEYS=5000
