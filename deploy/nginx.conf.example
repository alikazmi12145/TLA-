##
# TLA HRMS — Nginx reverse-proxy config with WebSocket upgrade.
#
# Copy the location blocks below into your existing `server { ... }` for the
# HRMS domain. The two things that MUST be right for `wss://` to succeed:
#
#   1) `proxy_http_version 1.1`
#   2) `proxy_set_header Upgrade $http_upgrade;`
#      `proxy_set_header Connection "upgrade";`
#
# Missing either of those is the single most common cause of the
# `wss://<domain>/socket.io/?EIO=4&transport=websocket failed` error you see
# in Chrome dev-tools. HTTP/1.0 (the Nginx default upstream) does not carry
# the Upgrade frame, so the WS handshake never completes and the client
# silently falls back to long-poll — which then times out and shows red.
##

# --- Optional but recommended: a shared `map` at http{} level tells Nginx
# when a request is an actual upgrade attempt. Add this OUTSIDE the server
# block, in the main http {} section (usually /etc/nginx/nginx.conf).
#
#   map $http_upgrade $connection_upgrade {
#       default upgrade;
#       ''      close;
#   }

server {
    listen 443 ssl http2;
    server_name YOUR_DOMAIN_HERE;

    # -- your existing ssl_certificate / ssl_certificate_key here --

    # Increase timeouts so long-lived websockets aren't cut every 60s.
    proxy_read_timeout  3600s;
    proxy_send_timeout  3600s;
    proxy_connect_timeout 60s;

    # -----------------------------------------------------------------
    # Socket.IO  --  keep this block ABOVE the generic /api and / blocks
    # so it matches first. Path is exactly what socket.io-client uses by
    # default (io.js sets `path: '/socket.io'`).
    # -----------------------------------------------------------------
    location /socket.io/ {
        proxy_pass         http://127.0.0.1:5000;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection "upgrade";
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        # Bufferring MUST be off for websockets — otherwise Nginx holds
        # frames until its buffer fills, which the client sees as a
        # frozen connection.
        proxy_buffering    off;
        proxy_cache        off;
    }

    # -----------------------------------------------------------------
    # REST API  (JSON, no upgrade needed)
    # -----------------------------------------------------------------
    location /api/ {
        proxy_pass         http://127.0.0.1:5000;
        proxy_http_version 1.1;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        # Upload endpoints accept up to 5 MB (multer limit); mirror that
        # here or the reverse proxy will 413 before Node sees the body.
        client_max_body_size 8m;
    }

    # -----------------------------------------------------------------
    # Static uploads served by Express  (profile pics, payslips, logos)
    # -----------------------------------------------------------------
    location /uploads/ {
        proxy_pass         http://127.0.0.1:5000;
        proxy_http_version 1.1;
        proxy_set_header   Host $host;
        proxy_cache_valid  200 5m;
    }

    # -----------------------------------------------------------------
    # Vite-built frontend  (static files served by Nginx directly)
    # -----------------------------------------------------------------
    root /var/www/tla-hrms/frontend/dist;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }
}

# -----------------------------------------------------------------
# HTTP → HTTPS redirect (Let's Encrypt / Certbot)
# -----------------------------------------------------------------
server {
    listen 80;
    server_name YOUR_DOMAIN_HERE;
    return 301 https://$host$request_uri;
}
